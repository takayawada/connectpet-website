{
  "version": 2,
  "builds": [
    { "src": "**/*.*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/about",     "dest": "/about.html" },
    { "src": "/service",   "dest": "/service.html" },
    { "src": "/carestore", "dest": "/carestore.html" },
    { "src": "/homecare",  "dest": "/homecare.html" },
    { "src": "/news",      "dest": "/news.html" },
    { "src": "/contact",   "dest": "/contact.html" },
    { "src": "/legal",     "dest": "/legal.html" },
    { "src": "/privacy",   "dest": "/privacy.html" }
  ]
}
